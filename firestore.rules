rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function isTemporaryTestOrderCreate() {
      return request.resource.data.keys().hasAll([
          "customer",
          "items",
          "itemCount",
          "subtotal",
          "currency",
          "paymentMethod",
          "paymentStatus",
          "status",
          "orderStatus",
          "orderNumber",
          "source",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.source == "test-checkout"
        && request.resource.data.paymentMethod == "cash"
        && request.resource.data.paymentStatus == "pending"
        && request.resource.data.status == "new"
        && request.resource.data.orderStatus == "new"
        && request.resource.data.currency == "EUR"
        && request.resource.data.orderNumber is string
        && request.resource.data.customer is map
        && request.resource.data.customer.name is string
        && request.resource.data.customer.name.size() > 0
        && request.resource.data.customer.phone is string
        && request.resource.data.customer.phone.size() > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.itemCount is number
        && request.resource.data.itemCount > 0
        && request.resource.data.subtotal is number
        && request.resource.data.subtotal > 0;
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isTemporaryTestOrderCreate();
      allow get: if isAdmin();
      allow list: if isAdmin() || request.query.limit <= 1;
      allow update, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email in [
          "admin@shawarma-time.local",
          "mustafa.chanel@hotmail.com"
        ];
      allow update, delete: if isAdmin();
    }
  }
}
